{
  "title": "Food Delivery Pipeline",
  "uid": "food-delivery-pipeline",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Orders Ingested / sec",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "rate(orders_ingested_total[1m])",
        "legendFormat": "orders/sec",
        "datasource": "Prometheus"
      }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 2,
      "title": "Orders by Status",
      "type": "bargauge",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 4 },
      "targets": [{
        "expr": "orders_by_status",
        "legendFormat": "{{status}}",
        "datasource": "Prometheus"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 3,
      "title": "Stage Latency p95 (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(order_stage_duration_seconds_bucket[2m]))",
        "legendFormat": "{{stage}} p95",
        "datasource": "Prometheus"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "title": "Downstream Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "rate(downstream_errors_total[1m])",
        "legendFormat": "{{service}} errors/sec",
        "datasource": "Prometheus"
      }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 5,
      "title": "Retry Attempts / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "targets": [{
        "expr": "rate(retry_attempts_total[1m])",
        "legendFormat": "{{stage}}",
        "datasource": "Prometheus"
      }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 6,
      "title": "Dead-Letter Queue Total",
      "type": "stat",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 6 },
      "targets": [{
        "expr": "dlq_orders_total",
        "legendFormat": "DLQ orders",
        "datasource": "Prometheus"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":5},{"color":"red","value":20}] } } }
    },
    {
      "id": 7,
      "title": "Celery Queue Depth",
      "type": "stat",
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 6 },
      "targets": [{
        "expr": "celery_queue_depth",
        "legendFormat": "{{queue}}",
        "datasource": "Prometheus"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
